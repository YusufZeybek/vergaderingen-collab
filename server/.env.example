# Render zet PORT zelf; lokaal default 10000.
PORT=10000

# MongoDB-connectiestring. Bij voorkeur een APARTE database voor de collab-state
# (niet de MyClubCore-club-data mengen). Bv. een gratis Atlas-cluster of een
# aparte DB-naam aan het einde van de URI:  ...mongodb.net/vergaderingen_collab
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/vergaderingen_collab

# HS256 gedeeld geheim — MOET identiek zijn aan COLLAB_JWT_SECRET in de PHP server-.env.
# Genereer met: openssl rand -hex 32
COLLAB_JWT_SECRET=

# Gedeeld geheim voor de PHP load/snapshot-bridge (X-Collab-Secret header).
# MOET identiek zijn aan COLLAB_SNAPSHOT_SECRET in de PHP server-.env.
COLLAB_SNAPSHOT_SECRET=

# De PHP-bridge die de HTML levert (seed) en de snapshot ontvangt.
PHP_BRIDGE_URL=https://personeel.kvcwesterlo.be/modules/vergaderingen/collab.php
